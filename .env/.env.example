# Copy this file to `.env` in this same folder, then fill in real values.
# Only `.env/.env.example` is committed; `.env/.env` and other files here stay local.
#
# PowerShell:
#   Copy-Item .env\.env.example .env\.env
#
# Cmd:
#   copy .env\.env.example .env\.env
#
# `.env/.env`, other paths under `.env/`, and `secrets/` are gitignored.

# --- Optional: connection strings & APIs (rename/remove as needed) ---
# DATABASE_CONNECTION_STRING=
# API_KEY=
# NUGET_AUTH_TOKEN=

# --- Optional: game / platform IDs ---
# STEAM_APP_ID=

# --- Optional: paths to proprietary assets outside the repo ---
# PROPRIETARY_ASSETS_ROOT=
