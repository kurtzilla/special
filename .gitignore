# --- OS ---
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Environment & secrets ---
# Tracked: .env/.env.example only. Copy to .env/.env for local secrets (ignored).
.env/*
!.env/.env.example
# Other root-level dotenv-style files (not the .env/ directory layout)
/.env.*
*.pfx
*.p12
*.pem
id_rsa
id_rsa.pub
secrets/

# --- direnv / local shell env ---
.envrc
.direnv/

# --- Logs & temp ---
*.log
*.tmp
*.temp
*.cache
*.bak
*.swp
*~

# --- VS Code (keep shared .vscode/ in git; ignore local-only) ---
*.code-workspace.local
.vscode/*.local.json
.history/

# --- .NET / C# / Visual Studio ---
bin/
obj/
out/
[Bb]uild/
[Ll]ogs/
artifacts/
TestResults/
*.trx
*.coverage
*.coveragexml
coverage/
*.user
*.userosscache
*.suo
*.cachefile
*.VC.db
*.VC.VC.opendb
project.lock.json
project.fragment.lock.json
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.DotSettings.user
.vs/

# --- NuGet (restore generates these in some setups) ---
*.nuget.props
*.nuget.targets

# --- JetBrains Rider ---
.idea/
*.sln.iml

# --- Node (tooling, docs, or web sidecars) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Misc tooling ---
.terraform/
*.tgz
